# Twitter / X API v2 (https://developer.twitter.com/)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Reddit (https://www.reddit.com/prefs/apps - create "script" app)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=PharmaRadar/1.0 by YourRedditUsername

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SOCIAL_MENTIONS=social-mentions

# Rate limits (optional)
# TWITTER_RATE_LIMIT_REQUESTS=300
# TWITTER_RATE_LIMIT_WINDOW_SEC=900
# REDDIT_RATE_LIMIT_REQUESTS=60
# REDDIT_RATE_LIMIT_WINDOW_SEC=60

# Poll interval between full cycles (seconds)
# POLL_INTERVAL_SEC=300
