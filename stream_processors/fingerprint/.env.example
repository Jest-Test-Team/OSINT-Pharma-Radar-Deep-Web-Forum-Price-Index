# Kafka（論壇新圖片連結 Topic）
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_IMAGE_LINKS=forum-image-links
KAFKA_GROUP_ID=fingerprint-matcher

# PostgreSQL（protected_image_hashes + leak_alerts）
